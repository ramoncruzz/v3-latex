                <ul class="space-y-2">
                  {['Precisa submeter artigos científicos', 'Cada revista exige um formato diferente', 'Já ouviu falar de LaTeX, mas acha complicado'].map(d => (
                    <li class="flex items-start gap-2 text-sm" style="color:var(--text-muted);">
                      <span class="mt-0.5 flex-shrink-0" style="color:#EF4444;"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></span>
                      {d}
                    </li>
                  ))}
                </ul>
              </div>
              <div class="rounded-xl p-4 border" style="background:rgba(34,197,94,0.04); border-color:rgba(34,197,94,0.15);">
                <p class="text-xs font-semibold uppercase tracking-wider mb-2" style="color:#22C55E;">Como o produto ajuda</p>
                <p class="text-sm leading-relaxed" style="color:var(--text-muted);">
                  Ana envia seu artigo e escolhe o template da revista ou padrão acadêmico, recebendo um paper estruturado em LaTeX pronto para submissão.
                </p>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── PROMPT ─────────────────────────────────────────────── -->
    <section id="prompt" class="py-20 lg:py-24" style="background:var(--bg-base);">
      <div class="max-w-4xl mx-auto px-6 lg:px-8">

        <div class="reveal mb-12">
          <span class="text-xs font-semibold tracking-widest uppercase px-3 py-1.5 rounded-full border"
            style="border-color:rgba(139,92,246,0.3); color:var(--accent-secondary); background:rgba(139,92,246,0.06);">
            Prompt Gerado
          </span>
          <h2 class="text-3xl md:text-4xl font-bold mt-5 mb-3" style="font-family:'Playfair Display',serif; color:var(--text-primary);">
            Prompt para a Landing Page
          </h2>
          <p style="color:var(--text-muted);">
            Baseado neste estudo de caso, este prompt foi gerado para construir a landing page completa com AstroJS + shadcn/ui.
          </p>
        </div>

        <!-- Prompt card -->
        <div class="reveal rounded-2xl border overflow-hidden" style="background:var(--bg-surface); border-color:var(--border-color);">

          <!-- Toolbar -->
          <div class="flex items-center justify-between px-5 py-3.5 border-b"
            style="background:var(--bg-elevated); border-color:var(--border-color);">
            <div class="flex items-center gap-3">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-500 opacity-70"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500 opacity-70"></div>
                <div class="w-3 h-3 rounded-full bg-green-500 opacity-70"></div>
              </div>
              <span class="text-xs font-mono" style="color:var(--text-subtle);">landing-page-prompt.md</span>
            </div>
            <button
              id="copy-btn"
              class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-xs font-medium transition-all hover:opacity-80 border"
              style="background:rgba(245,158,11,0.08); border-color:rgba(245,158,11,0.2); color:var(--accent-primary);"
              onclick="copyPrompt()"
            >
              <svg id="copy-icon" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
              </svg>
              <span id="copy-label">Copiar prompt</span>
            </button>
          </div>

          <!-- Content -->
          <div class="p-6 overflow-auto max-h-[600px]">
            <pre id="prompt-content" class="text-xs leading-6 font-mono whitespace-pre-wrap" style="color:var(--text-muted);">{prompt}</pre>
          </div>
        </div>

        <!-- View live page -->
        <div class="reveal mt-8 flex flex-wrap gap-4 items-center justify-between p-6 rounded-2xl border"
          style="background:var(--bg-surface); border-color:rgba(245,158,11,0.2);">
          <div>
            <p class="font-semibold" style="font-family:'Playfair Display',serif; color:var(--text-primary);">
              Ver landing page ao vivo
            </p>
            <p class="text-sm mt-1" style="color:var(--text-muted);">
              A landing page gerada por este prompt está disponível na raiz deste projeto.
            </p>
          </div>
          <a href="/"
            class="inline-flex items-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm transition-all hover:scale-105"
            style="background:var(--accent-primary); color:#0A0A0F;">
            Ver Landing Page →
          </a>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</Layout>

<script>
  function copyPrompt() {
    const content = document.getElementById('prompt-content')?.textContent || '';
    navigator.clipboard.writeText(content).then(() => {
      const label = document.getElementById('copy-label');
      const icon = document.getElementById('copy-icon');
      if (label) label.textContent = 'Copiado!';
      if (icon) icon.innerHTML = '<polyline points="20 6 9 17 4 12"/>';
      setTimeout(() => {
        if (label) label.textContent = 'Copiar prompt';
        if (icon) icon.innerHTML = '<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>';
      }, 2000);
    });
  }
  (window as any).copyPrompt = copyPrompt;
</script>
