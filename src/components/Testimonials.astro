---
const testimonials = [
  {
    name: 'Lucas M.',
    role: 'Engenharia Civil',
    institution: 'UFMG',
    initials: 'LM',
    color: '#F59E0B',
    text: '"Formatei meu TCC de 80 páginas em menos de 5 minutos. Meu orientador aprovou na primeira revisão sem nenhuma correção de formatação."',
    rating: 5,
  },
  {
    name: 'Dra. Carla S.',
    role: 'Pesquisadora',
    institution: 'USP',
    initials: 'CS',
    color: '#8B5CF6',
    text: '"Finalmente consigo submeter para revistas internacionais sem depender de ninguém com conhecimento em LaTeX. Muda completamente meu fluxo de trabalho."',
    rating: 5,
  },
  {
    name: 'Prof. André R.',
    role: 'Orientador de TCC',
    institution: 'UNICAMP',
    initials: 'AR',
    color: '#22C55E',
    text: '"Recomendo para todos os meus alunos. Elimina 90% das dúvidas de formatação logo no início do semestre e libera tempo para focar no conteúdo."',
    rating: 5,
  },
];

const metrics = [
  { value: 12400, suffix: '+', label: 'trabalhos formatados', target: 12400 },
  { value: 98, suffix: '%', label: 'aprovação 1ª revisão', target: 98 },
  { value: 4, suffix: '', label: 'normas suportadas', target: 4 },
  { value: 60, suffix: 's', label: 'por documento', target: 60, prefix: '< ' },
];
---

<section
  id="depoimentos"
  class="relative py-24 lg:py-32"
  style="background:var(--bg-surface);"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-16 reveal">
      <span class="inline-block text-xs font-semibold tracking-widest uppercase mb-4 px-3 py-1.5 rounded-full border"
        style="border-color:rgba(245,158,11,0.3); color:var(--accent-primary); background:rgba(245,158,11,0.06);">
        Depoimentos
      </span>
      <h2 class="text-4xl md:text-5xl font-bold mb-4" style="font-family:'Playfair Display',serif; color:var(--text-primary);">
        O que estudantes<br />estão dizendo
      </h2>
    </div>

    <!-- Testimonial cards -->
    <div class="grid md:grid-cols-3 gap-6 mb-20">
      {testimonials.map((t, i) => (
        <div class={`reveal reveal-delay-${i + 1} card-hover rounded-2xl border p-6 flex flex-col gap-5`}
          style="background:var(--bg-elevated); border-color:var(--border-color);">

          <!-- Stars -->
          <div class="flex gap-1">
            {Array.from({length: t.rating}).map(() => (
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#F59E0B" stroke="none">
                <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
              </svg>
            ))}
          </div>

          <!-- Quote text -->
          <p class="text-sm leading-relaxed flex-1 italic"
            style="color:var(--text-muted); font-family:'Playfair Display',serif;">
            {t.text}
          </p>

          <!-- Author -->
          <div class="flex items-center gap-3 pt-2 border-t" style="border-color:var(--border-color);">
            <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0"
              style={`background:rgba(${t.color === '#F59E0B' ? '245,158,11' : t.color === '#8B5CF6' ? '139,92,246' : '34,197,94'},0.15); color:${t.color}; font-family:'DM Sans',sans-serif;`}>
              {t.initials}
            </div>
            <div>
              <p class="text-sm font-semibold" style="color:var(--text-primary);">{t.name}</p>
              <p class="text-xs" style="color:var(--text-muted);">{t.role} · {t.institution}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Metrics -->
    <div class="reveal rounded-2xl border p-8 md:p-10"
      style="background:var(--bg-elevated); border-color:rgba(245,158,11,0.15);">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 divide-y md:divide-y-0 md:divide-x"
        style="--tw-divide-opacity:1; --tw-divide-color:var(--border-color);">
        {metrics.map((m, i) => (
          <div class={`flex flex-col items-center text-center ${i > 0 ? 'pt-6 md:pt-0 md:pl-8' : ''}`}>
            <span class="text-4xl md:text-5xl font-black mb-2"
              style={`font-family:'Playfair Display',serif; color:var(--accent-primary);`}>
              {m.prefix || ''}<span
                class="count-up"
                data-target={m.target}
                data-suffix={m.suffix}
              >{m.value.toLocaleString('pt-BR')}{m.suffix}</span>
            </span>
            <span class="text-sm" style="color:var(--text-muted);">{m.label}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
