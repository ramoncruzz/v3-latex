---
const steps = [
  {
    number: '01',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>`,
    title: 'Cole seu texto',
    description: 'Envie seu artigo, TCC ou paper. Qualquer formato de texto funciona — Word, PDF ou texto puro.',
  },
  {
    number: '02',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
    title: 'Escolha a norma',
    description: 'Selecione ABNT, APA, Vancouver ou IEEE. O sistema aplica todas as regras automaticamente — sem você precisar memorizar nada.',
  },
  {
    number: '03',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>`,
    title: 'Baixe pronto',
    description: 'Receba seu documento como PDF formatado, arquivo .tex editável — ou ambos. Pronto para entregar.',
  },
];
---

<section
  id="como-funciona"
  class="relative py-24 lg:py-32"
  style="background:var(--bg-base);"
>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-20 reveal">
      <span class="inline-block text-xs font-semibold tracking-widest uppercase mb-4 px-3 py-1.5 rounded-full border"
        style="border-color:rgba(139,92,246,0.3); color:var(--accent-secondary); background:rgba(139,92,246,0.06);">
        Como Funciona
      </span>
      <h2 class="text-4xl md:text-5xl font-bold mb-4" style="font-family:'Playfair Display',serif; color:var(--text-primary);">
        Simples como 1, 2, 3
      </h2>
      <p class="text-lg max-w-md mx-auto" style="color:var(--text-muted);">
        Do texto bruto ao documento perfeito em menos de um minuto.
      </p>
    </div>

    <!-- Steps timeline -->
    <div class="relative">
      <!-- Desktop connecting line -->
      <div class="hidden lg:block absolute top-16 left-0 right-0" style="z-index:0; padding:0 12.5%;">
        <svg width="100%" height="32" viewBox="0 0 800 32" preserveAspectRatio="none" fill="none">
          <line x1="0" y1="16" x2="800" y2="16" stroke="var(--border-color)" stroke-width="1.5" stroke-dasharray="8 6" class="timeline-dash" />
        </svg>
      </div>

      <!-- Steps grid -->
      <div class="grid lg:grid-cols-3 gap-8 lg:gap-12 relative z-10">
        {steps.map((step, i) => (
          <div class={`reveal reveal-delay-${i + 1} flex flex-col items-center text-center lg:items-start lg:text-left`}>

            <!-- Step number + icon -->
            <div class="relative mb-6">
              <!-- Number badge -->
              <span class="absolute -top-2 -right-2 w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold z-10"
                style="background:var(--accent-primary); color:#0A0A0F; font-family:'DM Sans',sans-serif;">
                {i + 1}
              </span>
              <!-- Icon circle -->
              <div class="w-16 h-16 rounded-2xl flex items-center justify-center border transition-all duration-300 hover:scale-110"
                style={`background:${i === 0 ? 'rgba(245,158,11,0.08)' : i === 1 ? 'rgba(139,92,246,0.08)' : 'rgba(34,197,94,0.08)'}; border-color:${i === 0 ? 'rgba(245,158,11,0.2)' : i === 1 ? 'rgba(139,92,246,0.2)' : 'rgba(34,197,94,0.2)'}; color:${i === 0 ? '#F59E0B' : i === 1 ? '#8B5CF6' : '#22C55E'};`}>
                <Fragment set:html={step.icon} />
              </div>
            </div>

            <!-- Text -->
            <h3 class="text-xl font-bold mb-3" style="font-family:'Playfair Display',serif; color:var(--text-primary);">
              {step.title}
            </h3>
            <p class="text-sm leading-relaxed" style="color:var(--text-muted);">
              {step.description}
            </p>
          </div>
        ))}
      </div>
    </div>

    <!-- Time indicator -->
    <div class="mt-20 reveal">
      <div class="rounded-2xl p-6 md:p-8 border flex flex-col md:flex-row items-center justify-between gap-6"
        style="background:var(--bg-surface); border-color:rgba(245,158,11,0.2);">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl flex items-center justify-center"
            style="background:rgba(245,158,11,0.1); color:var(--accent-primary);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
            </svg>
          </div>
          <div>
            <p class="font-semibold text-lg" style="font-family:'Playfair Display',serif; color:var(--text-primary);">
              Menos de 60 segundos
            </p>
            <p class="text-sm" style="color:var(--text-muted);">
              Do texto bruto ao documento formatado perfeito
            </p>
          </div>
        </div>
        <a
          href="#precos"
          class="flex-shrink-0 inline-flex items-center gap-2 px-5 py-3 rounded-xl font-semibold text-sm transition-all hover:scale-105"
          style="background:var(--accent-primary); color:#0A0A0F;"
        >
          Experimentar agora →
        </a>
      </div>
    </div>

  </div>
</section>
